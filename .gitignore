# ============================================================
# Ghost Creator AI — .gitignore
# ============================================================

# ── Node / Electron ───────────────────────────────────────────
node_modules/
dist-electron/
release/
build-api/
dist-api/
*.tsbuildinfo
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/

# ── Virtual Environments (Python — never commit) ────────────
venv/
.venv/
Venv/
ENV/
env/
virtualenv/

# ── Secrets — NEVER COMMIT ───────────────────────────────────
.env
.env.local
config.json
yt_client_secrets.json
yt_client_secrets.json.json
# build.bat removed — use build-api.bat + build-electron.bat

# ── Generated Media (large files — never commit) ─────────────
output/
temp/
*.png
*.jpg
*.mp4
*.mp3
*.wav

# ── Voice Reference (personal audio) ────────────────────────
my_voice_reference.wav

# ── Chatterbox TTS Server (separate git repo — clone independently) ──────────
# https://github.com/mirbehnam/Chatterbox-TTS-Server-windows-easyInstallation
Chatterbox-TTS-Server-windows-easyInstallation/

# ── HuggingFace model cache ──────────────────────────────────
.cache/

# ── Chrome Profile (personal login session) ─────────────────
ChromeProfiles/

# ── Debug / temp files ──────────────────────────────────────
output/debug_upload.png
*.log
_cb_health.txt

# ── Build / release (large binaries — do not commit) ────────
/GhostCreatorAI.exe
installer_output/


# ── Ghost Editor (Shotcut portable — not shipped) ───────────
ghost_editor/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
installer_v2.iss 
# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

